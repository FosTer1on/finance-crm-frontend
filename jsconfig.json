{
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "@/*": ["src/*"],
  
        "@api/*": ["src/api/*"],
        "@store/*": ["src/store/*"],
        "@components/*": ["src/components/*"],
        "@pages/*": ["src/pages/*"],
        "@hooks/*": ["src/shared/hooks/*"],
        "@layouts/*": ["src/layouts/*"],
        "@assets/*": ["src/assets/*"],
        "@utils/*": ["src/shared/utils/*"],
        "@constants/*": ["src/constants/*"]
      }
    },
  
    "exclude": [
      "node_modules",
      "dist"
    ]
  }